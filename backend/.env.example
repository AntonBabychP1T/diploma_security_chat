OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
DATABASE_URL=sqlite+aiosqlite:///./chat.db
LOG_LEVEL=INFO
MEMORY_EXTRACT_MODEL=gpt-5-mini
MEMORY_INJECT_MODEL=gpt-5-mini
OPENAI_MAX_COMPLETION_TOKENS=10000
MEMORY_EXTRACT_MAX_TOKENS=10000
MEMORY_INJECT_MAX_TOKENS=10000
AUDIO_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# Public frontend URL used to build Google OAuth redirect_uri
# Local dev: http://localhost:5173
# Ngrok: https://<subdomain>.ngrok-free.app
FRONTEND_PUBLIC_URL=http://localhost:5173

# Web Push (VAPID)
# Generate keys: python generate_vapid_keys.py
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_CLAIM_EMAIL=your-email@example.com

# Scheduler / Digests
SCHEDULER_TIMEZONE=Europe/Kyiv
POLL_INTERVAL_MINUTES=60
MORNING_DIGEST_HOUR=9
MORNING_DIGEST_MINUTE=0
EVENING_DIGEST_HOUR=19
EVENING_DIGEST_MINUTE=0

# PII engine
PII_V2_ENABLED=true
PII_TOKEN_FORMAT=v2
PII_CONTEXTUAL_NUMERIC_IDS=true
PII_STREAM_BUFFERING=true
