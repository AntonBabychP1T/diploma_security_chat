OPENAI_API_KEY=your_openai_api_key
GEMINI_API_KEY=your_gemini_api_key
DATABASE_URL=sqlite+aiosqlite:///./chat.db
LOG_LEVEL=INFO
OPENAI_DEFAULT_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium
OPENAI_TEXT_VERBOSITY=medium
MEMORY_EXTRACT_MODEL=gpt-5.4-mini
MEMORY_INJECT_MODEL=gpt-5.4-mini
SECRETARY_MODEL=gpt-5.4-mini
SECRETARY_MAX_TURNS=5
OPENAI_MAX_COMPLETION_TOKENS=10000
MEMORY_EXTRACT_MAX_TOKENS=10000
MEMORY_INJECT_MAX_TOKENS=10000
AUDIO_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
# Public frontend URL used to build Google OAuth redirect_uri
# Local dev: http://localhost:5173
# Ngrok: https://<subdomain>.ngrok-free.app
FRONTEND_PUBLIC_URL=http://localhost:5173
